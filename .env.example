# ──────────────────────────────────────────────────────────────
# ai-ps environment — copy to .env and fill in.
# Provider keys live ONLY here (loaded by api + workers). They must
# never be exposed to the browser bundle.
# ──────────────────────────────────────────────────────────────

# --- Core services ---
POSTGRES_USER=aips
POSTGRES_PASSWORD=aips_dev_password
POSTGRES_DB=aips
DATABASE_URL=postgresql://aips:aips_dev_password@postgres:5432/aips

REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=aips
MINIO_ROOT_PASSWORD=aips_dev_password
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=aips
MINIO_USE_SSL=false

# --- API ---
API_PORT=8080
# Comma-separated allowed origins for CORS (the Vite dev server, prod web origin)
WEB_ORIGIN=http://localhost:5173
# Secret for signing session/JWT tokens (change in prod)
JWT_SECRET=change_me_in_production

# --- AI providers (server-side only) ---
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default image model used for text-to-image / image edit
OPENROUTER_IMAGE_MODEL=google/gemini-3-pro-image-preview
# Text/chat model used for agent planning (POST /ai/agent). Optional — the API
# defaults to this value if unset.
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash

# Optional specialist providers (Phase 3)
FAL_KEY=
REPLICATE_API_TOKEN=

# --- Web (build-time, safe to expose) ---
VITE_API_URL=http://localhost:8080
