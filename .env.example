# ──────────────────────────────────────────────────────────────
# ai-ps environment — copy to .env and fill in.
# Provider keys live ONLY here (loaded by api + workers). They must
# never be exposed to the browser bundle.
# ──────────────────────────────────────────────────────────────

# --- Core services ---
POSTGRES_USER=aips
POSTGRES_PASSWORD=aips_dev_password
POSTGRES_DB=aips
DATABASE_URL=postgresql://aips:aips_dev_password@postgres:5432/aips

REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=aips
MINIO_ROOT_PASSWORD=aips_dev_password
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=aips
MINIO_USE_SSL=false

# --- API ---
API_PORT=8080
# Comma-separated allowed origins for CORS (the Vite dev server, prod web origin)
WEB_ORIGIN=http://localhost:5173
# Secret for signing session/JWT tokens. SERVER-SIDE ONLY — never reaches the
# browser bundle. REQUIRED in prod: when AUTH_DEV_MODE=false the API REFUSES TO
# BOOT if this is left at the placeholder below or is shorter than 32 chars.
# Generate a strong one with:  openssl rand -hex 32
JWT_SECRET=change_me_in_production

# --- Auth (JWT) ---
# When true (self-host default), the API auto-accepts a frictionless "dev-user"
# identity with NO login and grants effectively-unlimited credits. Set FALSE in
# production so missing/invalid tokens are rejected with 401.
AUTH_DEV_MODE=true
# `iss` claim baked into and verified on tokens.
JWT_ISSUER=aips
# Token lifetime in seconds (default 30 days).
JWT_TTL_SECONDS=2592000

# --- Credits / billing ---
# Integer credits per US dollar (100 -> 1 credit = $0.01).
CREDITS_PER_USD=100
# Credits granted on first dev-login (effectively unlimited for self-host).
DEV_DEFAULT_CREDITS=1000000
# Reservation = per-capability estimate x this multiplier (covers under-estimates).
CREDIT_SAFETY_MULTIPLIER=1.5
# Flat credits charged for the synchronous LLM endpoints.
SYNC_AGENT_COST_CREDITS=2
SYNC_DISTRACTIONS_COST_CREDITS=5
# Shared secret gating POST /admin/credits/grant (header `x-admin-token`).
# REQUIRED in prod: when AUTH_DEV_MODE=false the API REFUSES TO BOOT if this is
# unset, left at the old 'dev-admin-token' placeholder, or shorter than 16 chars
# (POST /admin/credits/grant mints real-money credits and has no other auth).
# In dev mode the header path is optional — the dev-login user's admin JWT
# already authorizes the grant — so it's safe to leave this BLANK for self-host.
# Generate a strong one for prod with:  openssl rand -hex 24
ADMIN_GRANT_TOKEN=

# --- Rate limiting ---
# Default per-user / per-IP requests per minute (global).
RATE_LIMIT_PER_MIN_DEFAULT=120
# Tighter caps for the money/provider endpoints.
RATE_LIMIT_AI_JOBS_PER_MIN=20
RATE_LIMIT_SYNC_PER_MIN=30
# Disable rate limiting entirely (frictionless self-host default). Set FALSE to
# enforce the caps above.
RATE_LIMIT_DEV_DISABLED=true

# --- Stripe (SCAFFOLDING ONLY) ---
# POST /billing/checkout-session is INERT (501) unless this is set. NO real
# card/Stripe credentials are wired in this project; leave blank for self-host.
STRIPE_SECRET_KEY=

# --- AI providers (server-side only) ---
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default image model used for text-to-image / image edit
OPENROUTER_IMAGE_MODEL=google/gemini-3-pro-image-preview
# Text/chat model used for agent planning (POST /ai/agent). Optional — the API
# defaults to this value if unset.
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash

# Optional specialist providers (Phase 3)
FAL_KEY=
REPLICATE_API_TOKEN=

# --- Web (build-time, safe to expose) ---
VITE_API_URL=http://localhost:8080
