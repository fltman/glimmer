# ──────────────────────────────────────────────────────────────
# ai-ps environment template (infra copy).
#
# The docker-compose stack in this directory loads `../.env` (the repo-root
# env file). The CANONICAL template lives at ../.env.example — copy THAT to
# ../.env:   cp .env.example .env   (from the repo root).
#
# This file mirrors the same variables so the infra dir is self-documenting.
# Provider keys, the JWT secret, DB creds and the admin token are SERVER-SIDE
# ONLY and must never reach the browser bundle (the web build sees only
# VITE_API_URL — a plain URL).
# ──────────────────────────────────────────────────────────────

# --- Core services ---
POSTGRES_USER=aips
POSTGRES_PASSWORD=aips_dev_password
POSTGRES_DB=aips
DATABASE_URL=postgresql://aips:aips_dev_password@postgres:5432/aips

REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=aips
MINIO_ROOT_PASSWORD=aips_dev_password
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=aips
MINIO_USE_SSL=false

# --- API ---
API_PORT=8080
WEB_ORIGIN=http://localhost:5173
# REQUIRED in prod: with AUTH_DEV_MODE=false the API refuses to boot if this is
# the placeholder below or shorter than 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# --- Auth (JWT) ---
AUTH_DEV_MODE=true
JWT_ISSUER=aips
JWT_TTL_SECONDS=2592000

# --- Credits / billing ---
CREDITS_PER_USD=100
DEV_DEFAULT_CREDITS=1000000
CREDIT_SAFETY_MULTIPLIER=1.5
SYNC_AGENT_COST_CREDITS=2
SYNC_DISTRACTIONS_COST_CREDITS=5
# REQUIRED in prod (AUTH_DEV_MODE=false): the API refuses to boot if unset, the
# old 'dev-admin-token' placeholder, or <16 chars. Blank is fine for dev/self-
# host (the dev-login admin JWT authorizes grants). Generate: openssl rand -hex 24
ADMIN_GRANT_TOKEN=

# --- Rate limiting ---
RATE_LIMIT_PER_MIN_DEFAULT=120
RATE_LIMIT_AI_JOBS_PER_MIN=20
RATE_LIMIT_SYNC_PER_MIN=30
RATE_LIMIT_DEV_DISABLED=true

# --- Stripe (SCAFFOLDING ONLY — inert unless set) ---
STRIPE_SECRET_KEY=

# --- AI providers (server-side only) ---
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_IMAGE_MODEL=google/gemini-3-pro-image-preview
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash

# Optional specialist providers (Phase 3)
FAL_KEY=
REPLICATE_API_TOKEN=

# --- Web (build-time, safe to expose) ---
VITE_API_URL=http://localhost:8080
